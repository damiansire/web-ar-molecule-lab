{
  "name": "web-ar-molecule-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "predev": "node scripts/vendor-mediapipe.mjs",
    "dev": "vite",
    "prebuild": "node scripts/vendor-mediapipe.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "tsc --noEmit && vitest run"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.35",
    "three": "^0.185.1"
  },
  "description": "Cuenco de alquimia en el navegador: combiná átomos y moléculas con la voz y el seguimiento de manos para descubrir un árbol de compuestos químicos."
}
